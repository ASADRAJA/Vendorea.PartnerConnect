@page "/catalog/prices"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject PortalState State

<PageTitle>Prices — PartnerConnect</PageTitle>

<div class="page-header">
    <h1 class="page-title">Prices</h1>
    <div class="command-bar">
        <FluentButton Appearance="Appearance.Stealth" Disabled="@(!HasTenantAndPartner)" OnClick="RefreshAsync">Refresh</FluentButton>
    </div>
</div>

@if (State.SelectedTenant is null)
{
    <FluentCard>
        <div class="empty-state">
            <div class="empty-title">Select a tenant</div>
            <div class="empty-sub">Choose a tenant from the switcher above to view its prices.</div>
        </div>
    </FluentCard>
}
else if (!_partnersLoaded)
{
    <FluentProgressRing />
}
else if (_partners.Count == 0)
{
    <FluentCard>
        <div class="empty-state">
            <div class="empty-title">No connected partners</div>
            <div class="empty-sub">@State.SelectedTenant.Name has no approved partner connections yet.</div>
        </div>
    </FluentCard>
}
else
{
    <div class="catalog-toolbar">
        @if (_partners.Count > 1)
        {
            <FluentSelect TOption="OrgCatalogPartnerDto"
                          Label="Partner"
                          Items="@_partners"
                          OptionText="@(p => p.PartnerName)"
                          OptionValue="@(p => p.PartnerCode)"
                          @bind-Value="_selectedPartnerCode"
                          @bind-Value:after="OnPartnerChanged"
                          Width="220px" />
        }
        <FluentSearch @bind-Value="_search"
                      @bind-Value:after="OnSearchAsync"
                      Placeholder="Search SKU or description"
                      Style="width: 320px;" />
    </div>

    <FluentDataGrid @ref="_grid" TGridItem="PriceRowDto" ItemsProvider="_provider" Pagination="_pagination"
                    GridTemplateColumns="1.2fr 3fr 1fr 1fr 0.7fr 1.4fr 0.8fr" Style="width: 100%;">
        <PropertyColumn Title="SKU" Property="@(p => p.Sku)" />
        <PropertyColumn Title="Description" Property="@(p => p.Description)" />
        <TemplateColumn Title="Cost" Align="Align.End">@Money(context.Cost)</TemplateColumn>
        <TemplateColumn Title="List" Align="Align.End">@Money(context.ListPrice)</TemplateColumn>
        <PropertyColumn Title="UOM" Property="@(p => p.Uom)" />
        <TemplateColumn Title="Last updated">@Fmt(context.LastUpdatedAt)</TemplateColumn>
        <TemplateColumn Title="" Align="Align.End">
            <FluentButton Appearance="Appearance.Lightweight" OnClick="@(() => ShowHistoryAsync(context.Sku))">History</FluentButton>
        </TemplateColumn>
    </FluentDataGrid>

    <FluentPaginator State="_pagination" />

    @if (_historySku is not null)
    {
        <FluentCard Class="history-panel">
            <div class="page-header">
                <h2 class="page-title">Price history — @_historySku</h2>
                <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => _historySku = null)">Close</FluentButton>
            </div>
            @if (_historyLoading)
            {
                <FluentProgressRing />
            }
            else if (_history is null || _history.Points.Count == 0)
            {
                <div class="tile-sub muted">No price history is tracked for this SKU (only the current price is available).</div>
            }
            else
            {
                <FluentDataGrid Items="@_history.Points.AsQueryable()" TGridItem="PriceHistoryPointDto"
                                GridTemplateColumns="1.4fr 1fr 1fr 0.7fr 1.2fr 1.2fr" Style="width: 100%;">
                    <TemplateColumn Title="Updated">@Fmt(context.UpdatedAt)</TemplateColumn>
                    <TemplateColumn Title="Cost" Align="Align.End">@Money(context.Cost)</TemplateColumn>
                    <TemplateColumn Title="List" Align="Align.End">@Money(context.ListPrice)</TemplateColumn>
                    <PropertyColumn Title="UOM" Property="@(p => p.Uom)" />
                    <TemplateColumn Title="Effective">@Fmt(context.EffectiveDate)</TemplateColumn>
                    <TemplateColumn Title="Ends">@Fmt(context.EndDate)</TemplateColumn>
                </FluentDataGrid>
            }
        </FluentCard>
    }
}

@code {
    private bool _partnersLoaded;
    private List<OrgCatalogPartnerDto> _partners = new();
    private string? _selectedPartnerCode;
    private string _search = string.Empty;

    private FluentDataGrid<PriceRowDto>? _grid;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 50 };
    private GridItemsProvider<PriceRowDto> _provider = default!;

    private string? _historySku;
    private bool _historyLoading;
    private PriceHistoryDto? _history;

    private bool HasTenantAndPartner => State.SelectedTenant is not null && _selectedPartnerCode is not null;

    protected override void OnInitialized()
    {
        State.OnChange += OnStateChanged;
        _provider = async request =>
        {
            if (State.SelectedTenant is null || _selectedPartnerCode is null)
                return GridItemsProviderResult.From(Array.Empty<PriceRowDto>(), 0);

            var take = request.Count ?? _pagination.ItemsPerPage;
            var page = await Api.GetPricesAsync(
                State.SelectedTenant.Id, _selectedPartnerCode, _search, request.StartIndex, take, request.CancellationToken);
            return GridItemsProviderResult.From(page.Items, page.Total);
        };
    }

    protected override async Task OnInitializedAsync() => await LoadPartnersAsync();

    private async Task LoadPartnersAsync()
    {
        _partnersLoaded = false;
        _historySku = null;
        if (State.SelectedTenant is null)
        {
            _partners = new();
            _partnersLoaded = true;
            return;
        }

        _partners = await Api.GetTenantPartnersAsync(State.SelectedTenant.Id);
        _selectedPartnerCode = _partners.FirstOrDefault()?.PartnerCode;
        _partnersLoaded = true;
        await RefreshGridAsync();
    }

    private void OnStateChanged() => _ = ReloadForTenantAsync();

    private async Task ReloadForTenantAsync()
    {
        await LoadPartnersAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnPartnerChanged() { _historySku = null; await RefreshGridAsync(); }
    private async Task OnSearchAsync() => await RefreshGridAsync();
    private async Task RefreshAsync() => await RefreshGridAsync();

    private async Task RefreshGridAsync()
    {
        if (_grid is not null)
            await _grid.RefreshDataAsync();
    }

    private async Task ShowHistoryAsync(string sku)
    {
        if (State.SelectedTenant is null || _selectedPartnerCode is null)
            return;
        _historySku = sku;
        _historyLoading = true;
        _history = null;
        _history = await Api.GetPriceHistoryAsync(State.SelectedTenant.Id, sku, _selectedPartnerCode);
        _historyLoading = false;
    }

    private static string Money(decimal value) => value.ToString("C2");
    private static string Fmt(DateTime? d) => d is { } v ? v.ToLocalTime().ToString("g") : "—";

    void IDisposable.Dispose() => State.OnChange -= OnStateChanged;
}
