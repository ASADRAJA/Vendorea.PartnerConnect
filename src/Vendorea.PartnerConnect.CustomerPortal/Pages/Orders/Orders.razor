@page "/orders"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject PortalState State
@inject NavigationManager Navigation

<PageTitle>Orders — PartnerConnect</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Orders</h1>
        <p class="page-subtitle">Purchase orders across your tenants and their document chain.</p>
    </div>
    <div class="command-bar">
        <FluentButton Appearance="Appearance.Stealth" OnClick="RefreshAsync">Refresh</FluentButton>
    </div>
</div>

<div class="catalog-toolbar">
    @* Tenant filter only when the caller can see more than one tenant. *@
    @if (_tenantOptions.Count > 2)
    {
        <FluentSelect TOption="string"
                      Label="Tenant"
                      Items="@_tenantOptions"
                      OptionText="@(id => TenantLabel(id))"
                      OptionValue="@(id => id)"
                      @bind-Value="_tenantFilter"
                      @bind-Value:after="RefreshAsync"
                      Width="200px" />
    }
    <FluentSelect TOption="string"
                  Label="Status"
                  Items="@_statusOptions"
                  OptionText="@(s => string.IsNullOrEmpty(s) ? "All statuses" : s)"
                  OptionValue="@(s => s)"
                  @bind-Value="_statusFilter"
                  @bind-Value:after="RefreshAsync"
                  Width="180px" />
    <FluentDatePicker Label="From" @bind-Value="_from" @bind-Value:after="RefreshAsync" />
    <FluentDatePicker Label="To" @bind-Value="_to" @bind-Value:after="RefreshAsync" />
    @if (_from is not null || _to is not null || !string.IsNullOrEmpty(_statusFilter) || !string.IsNullOrEmpty(_tenantFilter))
    {
        <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearFiltersAsync">Clear filters</FluentButton>
    }
</div>

<div class="grid-card">
    <FluentDataGrid @ref="_grid" TGridItem="OrderSummaryDto" ItemsProvider="_provider" Pagination="_pagination"
                    GridTemplateColumns="1.1fr 1.3fr 1.2fr 1.1fr 1fr 1.5fr 1fr 0.7fr" Style="width: 100%;">
        <PropertyColumn Title="PO #" Property="@(o => o.PoNumber)" />
        <PropertyColumn Title="Tenant" Property="@(o => o.TenantName)" />
        <PropertyColumn Title="Partner" Property="@(o => o.PartnerName)" />
        <TemplateColumn Title="Ordered">@Fmt(context.OrderedAt)</TemplateColumn>
        <TemplateColumn Title="Status">
            <FluentBadge Appearance="@StatusAppearance(context.Status)">@context.Status</FluentBadge>
        </TemplateColumn>
        <TemplateColumn Title="Chain">
            <div class="badge-row">
                @foreach (var stage in new[] { "PO", "ACK", "ASN", "Invoice" })
                {
                    var present = context.Chain.Contains(stage);
                    <FluentBadge Appearance="@(present ? Appearance.Accent : Appearance.Lightweight)">@stage</FluentBadge>
                }
            </div>
        </TemplateColumn>
        <TemplateColumn Title="Total" Align="Align.End">@Money(context.Total, context.Currency)</TemplateColumn>
        <TemplateColumn Title="" Align="Align.End">
            <FluentButton Appearance="Appearance.Outline" OnClick="@(() => View(context.Id))">View</FluentButton>
        </TemplateColumn>
    </FluentDataGrid>

    <FluentPaginator State="_pagination" />
</div>

@if (_loaded && _isEmpty)
{
    <FluentCard>
        <div class="empty-state">
            <div class="empty-title">No orders</div>
            <div class="empty-sub">No orders match the current filters.</div>
        </div>
    </FluentCard>
}

@code {
    private List<string> _tenantOptions = new();      // "" (All) + tenant ids
    private string? _tenantFilter = string.Empty;     // "" = all tenants
    private string? _statusFilter = string.Empty;     // "" = all statuses
    private DateTime? _from;
    private DateTime? _to;

    private readonly List<string> _statusOptions = new()
    {
        "", "Draft", "Submitted", "Acknowledged", "Processing", "PartiallyShipped",
        "Shipped", "Delivered", "Completed", "Cancelled", "Failed"
    };

    private FluentDataGrid<OrderSummaryDto>? _grid;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 50 };
    private GridItemsProvider<OrderSummaryDto> _provider = default!;
    private bool _loaded;
    private bool _isEmpty;

    protected override void OnInitialized()
    {
        State.OnChange += OnStateChanged;
        BuildTenantOptions();
        _provider = async request =>
        {
            var take = request.Count ?? _pagination.ItemsPerPage;
            int? tenantId = string.IsNullOrEmpty(_tenantFilter) ? null : int.Parse(_tenantFilter);
            var page = await Api.GetAllOrdersAsync(
                tenantId,
                string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter,
                _from, ToEndOfDay(_to),
                request.StartIndex, take, request.CancellationToken);

            _loaded = true;
            _isEmpty = page.Total == 0;
            return GridItemsProviderResult.From(page.Items, page.Total);
        };
    }

    private void BuildTenantOptions()
    {
        _tenantOptions = new List<string> { string.Empty };
        _tenantOptions.AddRange(State.Tenants.Select(t => t.Id.ToString()));
    }

    // The org context (and thus the visible-tenant list) loads asynchronously; rebuild the tenant
    // filter and refresh the grid when it arrives.
    private void OnStateChanged()
    {
        BuildTenantOptions();
        _ = InvokeAsync(async () =>
        {
            await RefreshGridAsync();
            StateHasChanged();
        });
    }

    private async Task ClearFiltersAsync()
    {
        _tenantFilter = string.Empty;
        _statusFilter = string.Empty;
        _from = null;
        _to = null;
        await RefreshGridAsync();
    }

    private async Task RefreshAsync() => await RefreshGridAsync();

    private async Task RefreshGridAsync()
    {
        if (_grid is not null)
            await _grid.RefreshDataAsync();
    }

    private void View(int id) => Navigation.NavigateTo($"/orders/{id}");

    private string TenantLabel(string id)
    {
        if (string.IsNullOrEmpty(id))
            return "All tenants";
        return State.Tenants.FirstOrDefault(t => t.Id.ToString() == id)?.Name ?? id;
    }

    private static DateTime? ToEndOfDay(DateTime? d) => d?.Date.AddDays(1).AddTicks(-1);

    private static string Money(decimal value, string currency)
        => value.ToString("C2") + (string.Equals(currency, "USD", StringComparison.OrdinalIgnoreCase) ? "" : $" {currency}");

    private static string Fmt(DateTime? d) => d is { } v ? v.ToLocalTime().ToString("g") : "—";

    private static Appearance StatusAppearance(string status) => status switch
    {
        "Completed" or "Delivered" or "Shipped" => Appearance.Accent,
        "Failed" or "Cancelled" => Appearance.Lightweight,
        _ => Appearance.Neutral
    };

    void IDisposable.Dispose() => State.OnChange -= OnStateChanged;
}
