@page "/connections"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>Connections — PartnerConnect</PageTitle>

<div class="page-header">
    <h1 class="page-title">Connections</h1>
    <FluentButton Appearance="Appearance.Stealth" OnClick="LoadAsync">Refresh</FluentButton>
</div>

@if (!_loaded)
{
    <FluentProgressRing />
}
else if (_connections.Count == 0)
{
    <FluentCard>
        <div class="empty-state">
            <div class="empty-title">No connections yet</div>
            <div class="empty-sub">Requesting a connection will be available in an upcoming release.</div>
        </div>
    </FluentCard>
}
else
{
    <FluentDataGrid Items="@_connections.AsQueryable()" TGridItem="OrgConnectionDto" GridTemplateColumns="2fr 1fr 1.5fr 1fr">
        <PropertyColumn Title="Partner" Property="@(c => c.PartnerLabel)" Sortable="true" />
        <TemplateColumn Title="Status" Sortable="false">
            <FluentBadge Appearance="@BadgeAppearance(context.DisplayStatus)">@context.DisplayStatus</FluentBadge>
        </TemplateColumn>
        <TemplateColumn Title="Last activity">
            @(context.LastActivity is { } d ? d.ToLocalTime().ToString("g") : "—")
        </TemplateColumn>
        <TemplateColumn Title="Actions" Align="Align.End">
            <FluentButton Appearance="Appearance.Outline" OnClick="@(() => View(context.Code))">View</FluentButton>
        </TemplateColumn>
    </FluentDataGrid>
}

@code {
    private bool _loaded;
    private List<OrgConnectionDto> _connections = new();

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loaded = false;
        _connections = await Api.GetConnectionsAsync();
        _loaded = true;
    }

    private void View(string code) => Navigation.NavigateTo($"/connections/{code}");

    private static Appearance BadgeAppearance(string status) => status.ToLowerInvariant() switch
    {
        "active" => Appearance.Accent,
        "pending" => Appearance.Neutral,
        _ => Appearance.Lightweight
    };
}
