@inherits LayoutComponentBase
@implements IDisposable
@inject ApiClient Api
@inject PortalState State
@inject NavigationManager Navigation

<FluentLayout>
    <FluentHeader>
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Width="100%">
            <span class="wordmark">Partner<span class="wordmark-accent">Connect</span></span>

            <FluentSpacer />

            @if (State.Context is not null)
            {
                <span class="org-name" title="Organization">@State.Context.Organization.Name</span>

                @if (State.Tenants.Count > 0)
                {
                    <FluentSelect TOption="OrgTenantDto"
                                  Items="@State.Tenants"
                                  OptionText="@(t => t.Name)"
                                  OptionValue="@(t => t.Id.ToString())"
                                  SelectedOption="@State.SelectedTenant"
                                  SelectedOptionChanged="OnTenantChanged"
                                  Width="200px"
                                  Style="min-width: 180px;" />
                }
            }

            <FluentButton Id="userMenuBtn" Appearance="Appearance.Stealth" OnClick="@(() => _userMenuOpen = !_userMenuOpen)">
                <FluentPersona Name="@UserDisplay" Initials="@Initials" ImageSize="28px" />
            </FluentButton>
            <FluentMenu Anchor="userMenuBtn" @bind-Open="_userMenuOpen" VerticalThreshold="170">
                <FluentMenuItem Disabled="true">@UserDisplay</FluentMenuItem>
                <FluentDivider />
                <FluentMenuItem OnClick="SignOut">Sign out</FluentMenuItem>
            </FluentMenu>
        </FluentStack>
    </FluentHeader>

    <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
        <NavMenu />
        <FluentBodyContent Class="body-content">
            <div class="content">
                @Body
            </div>
        </FluentBodyContent>
    </FluentStack>
</FluentLayout>

@* Fluent providers required by the library (toasts, dialogs, tooltips, message bars). *@
<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />

@code {
    private bool _userMenuOpen;

    private string UserDisplay =>
        State.Context?.User.DisplayName
        ?? State.Context?.Organization.Name
        ?? "Account";

    private string Initials
    {
        get
        {
            var source = UserDisplay;
            if (string.IsNullOrWhiteSpace(source)) return "?";
            var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return parts.Length switch
            {
                0 => "?",
                1 => parts[0][..1].ToUpperInvariant(),
                _ => (parts[0][..1] + parts[^1][..1]).ToUpperInvariant()
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateChanged;
        if (!State.Loaded)
        {
            var context = await Api.GetOrgContextAsync();
            State.SetContext(context);
        }
    }

    private void OnTenantChanged(OrgTenantDto? tenant) => State.SelectTenant(tenant);

    private void SignOut() => Navigation.NavigateTo("/account/logout", forceLoad: true);

    private void StateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.OnChange -= StateChanged;
}
