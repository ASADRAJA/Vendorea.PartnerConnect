@* Grouped command-center navigation. Uses Blazor's NavLink for automatic .active styling and
   inline SVG line icons (no Fluent Icons package). The Organization group is org-admin only. *@
@inject PortalState State
@implements IDisposable

<nav class="nav">
    <div class="nav-group">
        <div class="nav-group-label">Overview</div>
        <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
            @Icon("grid")
            <span>Dashboard</span>
        </NavLink>
    </div>

    <div class="nav-group">
        <div class="nav-group-label">Catalog</div>
        <NavLink class="nav-item" href="/catalog/prices">
            @Icon("tag")
            <span>Prices</span>
        </NavLink>
        <NavLink class="nav-item" href="/catalog/inventory">
            @Icon("box")
            <span>Inventory</span>
        </NavLink>
        <NavLink class="nav-item" href="/catalog/content">
            @Icon("file")
            <span>Content</span>
        </NavLink>
    </div>

    <div class="nav-group">
        <div class="nav-group-label">Connections</div>
        <NavLink class="nav-item" href="/connections">
            @Icon("link")
            <span>Connections</span>
        </NavLink>
    </div>

    <div class="nav-group">
        <div class="nav-group-label">Orders</div>
        <NavLink class="nav-item" href="/orders">
            @Icon("cart")
            <span>Orders</span>
        </NavLink>
    </div>

    <div class="nav-group">
        <div class="nav-group-label">Activity</div>
        <NavLink class="nav-item" href="/activity">
            @Icon("activity")
            <span>Activity</span>
        </NavLink>
    </div>

    @if (_isOrgAdmin)
    {
        <div class="nav-group">
            <div class="nav-group-label">Organization</div>
            <NavLink class="nav-item" href="/org/tenants">
                @Icon("building")
                <span>Tenants</span>
            </NavLink>
            <NavLink class="nav-item" href="/org/users">
                @Icon("users")
                <span>Users</span>
            </NavLink>
            <NavLink class="nav-item" href="/org/settings">
                @Icon("settings")
                <span>Settings</span>
            </NavLink>
        </div>
    }
</nav>

@code {
    // The Organization group is org-admin only. Role comes from /org/me (the "OrgAdmin" placeholder
    // today), so it shows for the current key; it will tighten when per-user identity lands.
    private bool _isOrgAdmin =>
        string.Equals(State.Context?.User.Role, "OrgAdmin", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized() => State.OnChange += OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    // Inline 24x24 line icons (stroke = currentColor). Kept tiny and dependency-free.
    private static readonly Dictionary<string, string> Paths = new()
    {
        ["grid"] = "<rect x='3' y='3' width='7' height='7'/><rect x='14' y='3' width='7' height='7'/><rect x='14' y='14' width='7' height='7'/><rect x='3' y='14' width='7' height='7'/>",
        ["tag"] = "<path d='M20.59 13.41 13.42 20.6a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z'/><line x1='7' y1='7' x2='7.01' y2='7'/>",
        ["box"] = "<path d='M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z'/><polyline points='3.27 6.96 12 12.01 20.73 6.96'/><line x1='12' y1='22.08' x2='12' y2='12'/>",
        ["file"] = "<path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14 2 14 8 20 8'/><line x1='8' y1='13' x2='16' y2='13'/><line x1='8' y1='17' x2='16' y2='17'/>",
        ["link"] = "<path d='M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71'/><path d='M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71'/>",
        ["cart"] = "<circle cx='9' cy='21' r='1'/><circle cx='20' cy='21' r='1'/><path d='M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6'/>",
        ["activity"] = "<polyline points='22 12 18 12 15 21 9 3 6 12 2 12'/>",
        ["building"] = "<rect x='4' y='2' width='16' height='20' rx='2'/><line x1='9' y1='7' x2='9' y2='7'/><line x1='15' y1='7' x2='15' y2='7'/><line x1='9' y1='12' x2='9' y2='12'/><line x1='15' y1='12' x2='15' y2='12'/><path d='M10 22v-4h4v4'/>",
        ["users"] = "<path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M23 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/>",
        ["settings"] = "<circle cx='12' cy='12' r='3'/><path d='M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z'/>",
    };

    private static MarkupString Icon(string name)
    {
        var body = Paths.TryGetValue(name, out var p) ? p : string.Empty;
        return new MarkupString(
            $"<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round'>{body}</svg>");
    }

    public void Dispose() => State.OnChange -= OnStateChanged;
}
