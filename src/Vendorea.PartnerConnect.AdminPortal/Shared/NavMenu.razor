<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PartnerConnect Admin</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-dashboard" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="organizations">
                <span class="oi oi-organization" aria-hidden="true"></span> Organizations
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tenants">
                <span class="oi oi-person" aria-hidden="true"></span> Tenants
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="orders">
                <span class="oi oi-cart" aria-hidden="true"></span> Orders
            </NavLink>
        </div>
        <AuthorizeView Policy="RequireAdmin">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="partners">
                    <span class="oi oi-people" aria-hidden="true"></span> Trading Partners
                </NavLink>
            </div>
        </AuthorizeView>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tenant-connections">
                <span class="oi oi-link-intact" aria-hidden="true"></span> Partner Connections
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="documents">
                <span class="oi oi-document" aria-hidden="true"></span> Documents
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pricefeeds">
                <span class="oi oi-spreadsheet" aria-hidden="true"></span> Price Feeds
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="content">
                <span class="oi oi-box" aria-hidden="true"></span> Enhanced Content
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="ftp-ingestion">
                <span class="oi oi-cloud-download" aria-hidden="true"></span> Content Ingestion
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="webhooks">
                <span class="oi oi-bolt" aria-hidden="true"></span> Webhooks
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="billing">
                <span class="oi oi-credit-card" aria-hidden="true"></span> Billing Plans
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="audit">
                <span class="oi oi-clipboard" aria-hidden="true"></span> Audit Logs
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="cron-jobs">
                <span class="oi oi-timer" aria-hidden="true"></span> Cron Jobs
            </NavLink>
        </div>

        @* Admin-only: power/testing tools and user management *@
        <AuthorizeView Policy="RequireAdmin">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="spr-simulation">
                    <span class="oi oi-pulse" aria-hidden="true"></span> SPR Simulation
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="api-tester">
                    <span class="oi oi-terminal" aria-hidden="true"></span> API Tester
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="users">
                    <span class="oi oi-people" aria-hidden="true"></span> Users
                </NavLink>
            </div>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
