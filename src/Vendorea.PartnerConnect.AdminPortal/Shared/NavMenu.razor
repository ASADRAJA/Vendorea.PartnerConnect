<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PartnerConnect Admin</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-dashboard" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="partners">
                <span class="oi oi-people" aria-hidden="true"></span> Trading Partners
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="connections">
                <span class="oi oi-link-intact" aria-hidden="true"></span> Connections
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="subscriptions">
                <span class="oi oi-key" aria-hidden="true"></span> Subscriptions
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="documents">
                <span class="oi oi-document" aria-hidden="true"></span> Documents
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pricefeeds">
                <span class="oi oi-spreadsheet" aria-hidden="true"></span> Price Feeds
            </NavLink>
        </div>
        <div class="nav-item px-3">
