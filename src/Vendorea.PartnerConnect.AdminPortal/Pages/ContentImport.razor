@page "/content"
@using Vendorea.PartnerConnect.AdminPortal.Models
@using Vendorea.PartnerConnect.AdminPortal.Services
@inject ApiClient Api
@inject IJSRuntime JS

<PageTitle>Enhanced Content - PartnerConnect Admin</PageTitle>

<h1>Enhanced Content Management</h1>
<p class="text-muted">Enhanced content is supplier-specific but shared across all merchants subscribed to that supplier.</p>

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <span class="oi oi-cloud-upload me-2"></span> Import Enhanced Content
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Trading Partner (Supplier)</label>
                        <select class="form-select" @bind="selectedTradingPartnerId">
                            <option value="0">-- Select Supplier --</option>
                            @foreach (var partner in subscribedPartners)
                            {
                                <option value="@partner.Id">@partner.Name (@partner.Code)</option>
                            }
                        </select>
                        @if (subscribedPartners.Count == 0)
                        {
                            <small class="text-warning">No partners with active subscriptions</small>
                        }
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Content Version</label>
                        <input type="text" class="form-control" @bind="contentVersion" placeholder="e.g., 2024.01" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Locale</label>
                        <select class="form-select" @bind="selectedLocale">
                            <option value="EN_US">EN_US (English US)</option>
                            <option value="EN_CA">EN_CA (English Canada)</option>
                            <option value="ES_US">ES_US (Spanish US)</option>
                            <option value="FR_CA">FR_CA (French Canada)</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Content ZIP File</label>
                        <InputFile OnChange="OnFileSelected" class="form-control" accept=".zip" />
                        @if (selectedFile != null)
                        {
                            <small class="text-muted">@selectedFile.Name (@FormatFileSize(selectedFile.Size))</small>
                        }
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <AuthorizeView Policy="RequireOperator" Context="auth">
                            <button class="btn btn-primary w-100" @onclick="ImportContent" disabled="@(!CanImport || isImporting)">
                                @if (isImporting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <span>Importing...</span>
                                }
                                else
                                {
                                    <span class="oi oi-cloud-upload me-1"></span>
                                    <span>Import</span>
                                }
                            </button>
                        </AuthorizeView>
                    </div>
                </div>

                @if (importProgress != null && isImporting)
                {
                    <div class="mt-3">
                        <div class="progress" style="height: 25px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated"
                                 role="progressbar"
                                 style="width: @importProgress.PercentComplete.ToString("F0")%">
                                @importProgress.CurrentPhase - @importProgress.PercentComplete.ToString("F0")%
                            </div>
                        </div>
                        <small class="text-muted">
                            Products: @importProgress.ProcessedProducts / @importProgress.TotalProducts |
                            Features: @importProgress.ProcessedFeatures |
                            Relationships: @importProgress.ProcessedRelationships
                        </small>
                    </div>
                }

                @if (importResult != null)
                {
                    <div class="mt-3">
                        @if (importResult.Status == "Completed" || importResult.Status == "PartiallyCompleted")
                        {
                            <div class="alert @(importResult.ErrorProducts > 0 ? "alert-warning" : "alert-success")">
                                <strong>@(importResult.ErrorProducts > 0 ? "Import Completed with Errors" : "Import Successful!")</strong>
                                <ul class="mb-0 mt-2">
                                    <li>Total products: @importResult.TotalProducts.ToString("N0")</li>
                                    <li>Processed: @importResult.ProcessedProducts.ToString("N0")</li>
                                    <li>Errors: @importResult.ErrorProducts.ToString("N0")</li>
                                    <li>Upload ID: @importResult.UploadId</li>
                                </ul>
                            </div>
                        }
                        else if (importResult.Status == "Failed")
                        {
                            <div class="alert alert-danger">
                                <strong>Import Failed!</strong> Check the import history for details.
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><span class="oi oi-clock me-2"></span> Import History</span>
                <button class="btn btn-sm btn-outline-primary" @onclick="LoadHistory">
                    <span class="oi oi-reload"></span> Refresh
                </button>
            </div>
            <div class="card-body">
                @if (isLoadingHistory)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary"></div>
                        <p class="mt-2">Loading history...</p>
                    </div>
                }
                else if (importHistory.Count == 0)
                {
                    <p class="text-muted text-center py-4">No import history found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Supplier</th>
                                    <th>Version</th>
                                    <th>Locale</th>
                                    <th>Status</th>
                                    <th>Products</th>
                                    <th>Errors</th>
                                    <th>File</th>
                                    <th>Uploaded</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var upload in importHistory)
                                {
                                    <tr>
                                        <td>@upload.UploadId</td>
                                        <td><strong>@upload.TradingPartnerName</strong></td>
                                        <td><code>@upload.ContentVersion</code></td>
                                        <td>@upload.LocaleId</td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(upload.Status)">@upload.Status</span>
                                        </td>
                                        <td>@upload.TotalProducts.ToString("N0")</td>
                                        <td>
                                            @if (upload.ErrorProducts > 0)
                                            {
                                                <span class="text-danger">@upload.ErrorProducts</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td title="@upload.FileName">@TruncateFileName(upload.FileName)</td>
                                        <td>@upload.UploadedAt.ToLocalTime().ToString("g")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-info me-1" @onclick="() => ViewStatus(upload.UploadId)" title="View Status">
                                                <span class="oi oi-eye"></span>
                                            </button>
                                            <AuthorizeView Policy="RequireOperator" Context="auth">
                                            @if (upload.Status == "Pending" || upload.Status == "Extracting" || upload.Status == "Parsing" || upload.Status == "Importing")
                                            {
                                                <button class="btn btn-sm btn-outline-warning" @onclick="() => CancelImport(upload.UploadId)" title="Cancel">
                                                    <span class="oi oi-x"></span>
                                                </button>
                                            }
                                            @if (upload.Status == "Completed" || upload.Status == "PartiallyCompleted")
                                            {
                                                @if (upload.PushedToM360At == null)
                                                {
                                                    <button class="btn btn-sm btn-success me-1"
                                                            @onclick="() => PushToM360(upload.UploadId)"
                                                            disabled="@(pushingUploadId == upload.UploadId)"
                                                            title="Push to M360">
                                                        @if (pushingUploadId == upload.UploadId)
                                                        {
                                                            <span class="spinner-border spinner-border-sm"></span>
                                                        }
                                                        else
                                                        {
                                                            <span class="oi oi-cloud-upload"></span>
                                                        }
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success me-1" title="Pushed @upload.PushedToM360At?.ToLocalTime().ToString("g")">
                                                        <span class="oi oi-check"></span> Pushed
                                                    </span>
                                                    <button class="btn btn-sm btn-outline-success me-1"
                                                            @onclick="() => PushToM360(upload.UploadId)"
                                                            disabled="@(pushingUploadId == upload.UploadId)"
                                                            title="Re-push to M360">
                                                        @if (pushingUploadId == upload.UploadId)
                                                        {
                                                            <span class="spinner-border spinner-border-sm"></span>
                                                        }
                                                        else
                                                        {
                                                            <span class="oi oi-loop-circular"></span>
                                                        }
                                                        Re-push
                                                    </button>
                                                }
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(upload.UploadId)" title="Delete">
                                                    <span class="oi oi-trash"></span>
                                                </button>
                                            }
                                            </AuthorizeView>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <span class="oi oi-bar-chart me-2"></span> Content Statistics
            </div>
            <div class="card-body">
                @if (stats != null)
                {
                    <div class="row text-center">
                        <div class="col-md-2">
                            <h3 class="text-primary">@stats.TotalProducts.ToString("N0")</h3>
                            <small class="text-muted">Products</small>
                        </div>
                        <div class="col-md-2">
                            <h3 class="text-info">@stats.TotalBrands.ToString("N0")</h3>
                            <small class="text-muted">Brands</small>
                        </div>
                        <div class="col-md-2">
                            <h3 class="text-success">@stats.TotalCategories.ToString("N0")</h3>
                            <small class="text-muted">Categories</small>
                        </div>
                        <div class="col-md-3">
                            <h6>@(stats.LastContentVersion ?? "N/A")</h6>
                            <small class="text-muted">Last Version</small>
                        </div>
                        <div class="col-md-3">
                            <h6>@(stats.LastImportDate?.ToLocalTime().ToString("g") ?? "N/A")</h6>
                            <small class="text-muted">Last Import</small>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">Loading statistics...</p>
                }
            </div>
        </div>
    </div>
</div>

@if (selectedStatus != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Import Status #@selectedStatus.UploadId</h5>
                    <button type="button" class="btn-close" @onclick="CloseStatus"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl>
                                <dt>Status</dt>
                                <dd><span class="badge @GetStatusBadgeClass(selectedStatus.Status)">@selectedStatus.Status</span></dd>
                                <dt>Current Phase</dt>
                                <dd>@selectedStatus.CurrentPhase</dd>
                                <dt>Progress</dt>
                                <dd>
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar" role="progressbar" style="width: @selectedStatus.PercentComplete.ToString("F0")%">
                                            @selectedStatus.PercentComplete.ToString("F1")%
                                        </div>
                                    </div>
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl>
                                <dt>Products</dt>
                                <dd>@selectedStatus.ProcessedProducts.ToString("N0") / @selectedStatus.TotalProducts.ToString("N0")</dd>
                                <dt>Features</dt>
                                <dd>@selectedStatus.ProcessedFeatures.ToString("N0")</dd>
                                <dt>Relationships</dt>
                                <dd>@selectedStatus.ProcessedRelationships.ToString("N0")</dd>
                                <dt>Errors</dt>
                                <dd class="@(selectedStatus.ErrorProducts > 0 ? "text-danger" : "")">@selectedStatus.ErrorProducts.ToString("N0")</dd>
                            </dl>
                        </div>
                    </div>

                    @if (selectedStatus.Errors.Count > 0)
                    {
                        <h6 class="text-danger">Errors</h6>
                        <ul class="text-danger small">
                            @foreach (var error in selectedStatus.Errors.Take(10))
                            {
                                <li>@error</li>
                            }
                        </ul>
                    }

                    @if (!string.IsNullOrEmpty(selectedStatus.ErrorDetails))
                    {
                        <div class="alert alert-danger">
                            <strong>Error Details:</strong> @selectedStatus.ErrorDetails
                        </div>
                    }

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <small class="text-muted">Started: @(selectedStatus.StartedAt?.ToLocalTime().ToString("g") ?? "N/A")</small>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Completed: @(selectedStatus.CompletedAt?.ToLocalTime().ToString("g") ?? "N/A")</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseStatus">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteConfirm = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this content import? This will remove all product content associated with this upload.</p>
                    <p class="text-danger"><strong>This action cannot be undone.</strong></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteImport" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showPushProgress)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header @(pushProgress?.Success == true ? "bg-success text-white" : pushProgress?.IsComplete == true && pushProgress?.Success == false ? "bg-danger text-white" : "")">
                    <h5 class="modal-title">
                        @if (pushProgress?.IsComplete == true)
                        {
                            @(pushProgress.Success ? "Push Complete" : "Push Failed")
                        }
                        else
                        {
                            <span>Pushing to Merchant360...</span>
                        }
                    </h5>
                    @if (pushProgress?.IsComplete == true)
                    {
                        <button type="button" class="btn-close" @onclick="ClosePushProgress"></button>
                    }
                </div>
                <div class="modal-body">
                    @if (pushProgress != null)
                    {
                        <div class="mb-3">
                            <strong>Status:</strong> @pushProgress.PhaseDescription
                        </div>

                        <div class="progress mb-3" style="height: 30px;">
                            <div class="progress-bar @(pushProgress.IsComplete && !pushProgress.Success ? "bg-danger" : pushProgress.IsComplete && pushProgress.Success ? "bg-success" : "progress-bar-striped progress-bar-animated")"
                                 role="progressbar"
                                 style="width: @pushProgress.PercentComplete.ToString("F0")%">
                                @pushProgress.PercentComplete.ToString("F0")%
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <h6>Categories</h6>
                                <div class="d-flex justify-content-between">
                                    <span>Pushed:</span>
                                    <span>@pushProgress.CategoriesPushed.ToString("N0") / @pushProgress.TotalCategories.ToString("N0")</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h6>Products</h6>
                                <div class="d-flex justify-content-between">
                                    <span>Pushed:</span>
                                    <span>@pushProgress.ProductsPushed.ToString("N0") / @pushProgress.TotalProducts.ToString("N0")</span>
                                </div>
                                @if (pushProgress.TotalBatches > 0)
                                {
                                    <div class="d-flex justify-content-between">
                                        <span>Batch:</span>
                                        <span>@pushProgress.CurrentBatch / @pushProgress.TotalBatches</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (pushProgress.IsComplete)
                        {
                            <hr />
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <h4 class="text-success">@pushProgress.RecordsCreated.ToString("N0")</h4>
                                        <small class="text-muted">Created</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <h4 class="text-info">@pushProgress.RecordsUpdated.ToString("N0")</h4>
                                        <small class="text-muted">Updated</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <h4 class="text-warning">@pushProgress.RecordsSkipped.ToString("N0")</h4>
                                        <small class="text-muted">Skipped</small>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(pushProgress.ErrorMessage))
                            {
                                <div class="alert alert-danger mt-3">
                                    <strong>Error:</strong> @pushProgress.ErrorMessage
                                </div>
                            }

                            @if (pushProgress.Errors.Count > 0)
                            {
                                <div class="mt-3">
                                    <h6 class="text-danger">Errors (@pushProgress.Errors.Count)</h6>
                                    <ul class="small text-danger">
                                        @foreach (var error in pushProgress.Errors.Take(5))
                                        {
                                            <li>@error</li>
                                        }
                                        @if (pushProgress.Errors.Count > 5)
                                        {
                                            <li>... and @(pushProgress.Errors.Count - 5) more</li>
                                        }
                                    </ul>
                                </div>
                            }

                            <div class="mt-3 small text-muted">
                                <div>Started: @pushProgress.StartedAt.ToLocalTime().ToString("g")</div>
                                @if (pushProgress.CompletedAt.HasValue)
                                {
                                    <div>Completed: @pushProgress.CompletedAt.Value.ToLocalTime().ToString("g")</div>
                                    var duration = pushProgress.CompletedAt.Value - pushProgress.StartedAt;
                                    <div>Duration: @duration.ToString(@"mm\:ss")</div>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    @if (pushProgress?.IsComplete == true)
                    {
                        <button type="button" class="btn btn-primary" @onclick="ClosePushProgress">Close</button>
                    }
                    else
                    {
                        <span class="text-muted">Please wait while content is being pushed...</span>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ContentImportSummaryDto> importHistory = new();
    private ContentStatisticsDto? stats;
    private List<TradingPartnerDto> tradingPartners = new();
    private List<TradingPartnerDto> subscribedPartners = new();

    private int selectedTradingPartnerId;
    private string contentVersion = "";
    private string selectedLocale = "EN_US";
    private IBrowserFile? selectedFile;
    private bool isImporting;
    private ContentImportResultDto? importResult;
    private ContentImportProgressDto? importProgress;

    private bool isLoadingHistory;

    private ContentImportStatusDto? selectedStatus;

    private bool showDeleteConfirm;
    private int? deleteUploadId;
    private bool isDeleting;

    private int? pushingUploadId;
    private string? pushError;
    private ContentPushResultDto? pushResult;
    private bool showPushProgress;
    private M360PushProgressDto? pushProgress;
    private System.Threading.Timer? _pushPollTimer;

    private bool CanImport => selectedTradingPartnerId > 0 && !string.IsNullOrEmpty(contentVersion) && selectedFile != null;

    protected override async Task OnInitializedAsync()
    {
        // Load trading partners first (doesn't require M360)
        tradingPartners = await Api.GetTradingPartnersAsync();

        // Try to get subscriptions from M360, but don't block if M360 is unavailable
        try
        {
            var merchantsWithSubs = await Api.GetMerchantsWithActiveSubscriptionsAsync();

            if (merchantsWithSubs.Count > 0)
            {
                // Filter to only show partners that have at least one active subscription
                var subscribedPartnerIds = merchantsWithSubs
                    .SelectMany(m => m.Partners)
                    .Select(p => p.TradingPartnerId)
                    .Distinct()
                    .ToHashSet();

                subscribedPartners = tradingPartners
                    .Where(p => subscribedPartnerIds.Contains(p.Id))
                    .ToList();
            }
            else
            {
                // No subscriptions found - show all trading partners
                subscribedPartners = tradingPartners.ToList();
            }
        }
        catch
        {
            // M360 unavailable - show all trading partners for testing
            subscribedPartners = tradingPartners.ToList();
        }

        await LoadHistory();
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        importResult = null;
        importProgress = null;
    }

    private async Task ImportContent()
    {
        if (!CanImport || selectedFile == null) return;

        isImporting = true;
        importResult = null;
        importProgress = new ContentImportProgressDto { CurrentPhase = "Starting...", PercentComplete = 0 };

        try
        {
            // Max 500MB file size
            using var stream = selectedFile.OpenReadStream(maxAllowedSize: 500 * 1024 * 1024);
            importResult = await Api.ImportContentAsync(
                selectedTradingPartnerId,
                contentVersion,
                selectedLocale,
                stream,
                selectedFile.Name);

            await LoadHistory();
        }
        catch (Exception ex)
        {
            importResult = new ContentImportResultDto { Status = "Failed" };
            importProgress = null;
        }
        finally
        {
            isImporting = false;
            importProgress = null;
        }
    }

    private async Task LoadHistory()
    {
        isLoadingHistory = true;
        try
        {
            importHistory = await Api.GetContentImportHistoryAsync();
            stats = await Api.GetContentStatisticsAsync(selectedLocale);
        }
        finally
        {
            isLoadingHistory = false;
        }
    }

    private async Task ViewStatus(int uploadId)
    {
        selectedStatus = await Api.GetContentImportStatusAsync(uploadId);
    }

    private void CloseStatus()
    {
        selectedStatus = null;
    }

    private async Task CancelImport(int uploadId)
    {
        await Api.CancelContentImportAsync(uploadId);
        await LoadHistory();
    }

    private void ConfirmDelete(int uploadId)
    {
        deleteUploadId = uploadId;
        showDeleteConfirm = true;
    }

    private async Task DeleteImport()
    {
        if (!deleteUploadId.HasValue) return;

        isDeleting = true;
        try
        {
            await Api.DeleteContentImportAsync(deleteUploadId.Value);
            showDeleteConfirm = false;
            deleteUploadId = null;
            await LoadHistory();
        }
        finally
        {
            isDeleting = false;
        }
    }

    private async Task PushToM360(int uploadId)
    {
        pushingUploadId = uploadId;
        pushError = null;
        pushResult = null;
        showPushProgress = true;
        pushProgress = null;

        try
        {
            // Start the push
            pushProgress = await Api.StartM360PushAsync(uploadId);

            if (pushProgress == null)
            {
                pushProgress = new M360PushProgressDto
                {
                    UploadId = uploadId,
                    Phase = "Failed",
                    PhaseDescription = "Failed to start push",
                    IsComplete = true,
                    Success = false,
                    ErrorMessage = "No response from server"
                };
                pushingUploadId = null;
                StateHasChanged();
                return;
            }

            // Start polling for progress
            _pushPollTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    try
                    {
                        var progress = await Api.GetM360PushProgressAsync(uploadId);
                        if (progress != null)
                        {
                            pushProgress = progress;
                            StateHasChanged();

                            if (progress.IsComplete)
                            {
                                StopPushPolling();
                                await LoadHistory();
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        // Log but don't stop polling on transient errors
                        Console.WriteLine($"Polling error: {ex.Message}");
                    }
                });
            }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(2));
        }
        catch (Exception ex)
        {
            pushProgress = new M360PushProgressDto
            {
                UploadId = uploadId,
                Phase = "Failed",
                PhaseDescription = "Push failed",
                IsComplete = true,
                Success = false,
                ErrorMessage = ex.Message
            };
            pushingUploadId = null;
            StateHasChanged();
        }
    }

    private void StopPushPolling()
    {
        _pushPollTimer?.Dispose();
        _pushPollTimer = null;
        pushingUploadId = null;
        StateHasChanged();
    }

    private async Task ClosePushProgress()
    {
        StopPushPolling();
        showPushProgress = false;
        pushProgress = null;
        StateHasChanged();
        await LoadHistory();
    }

    private string GetStatusBadgeClass(string status) => status?.ToLower() switch
    {
        "pending" => "bg-warning text-dark",
        "extracting" => "bg-info",
        "parsing" => "bg-info",
        "importing" => "bg-info",
        "completed" => "bg-success",
        "partiallycompleted" => "bg-warning text-dark",
        "failed" => "bg-danger",
        "cancelled" => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private static string TruncateFileName(string fileName, int maxLength = 30)
    {
        if (string.IsNullOrEmpty(fileName) || fileName.Length <= maxLength)
            return fileName;
        return fileName.Substring(0, maxLength - 3) + "...";
    }
}
