@page "/partners"
@inject ApiClient Api

<PageTitle>Trading Partners - PartnerConnect Admin</PageTitle>

<h1>Trading Partners</h1>
<p class="text-muted">Partners are provisioned into the platform as they become available. Edit a partner to define the connection requirements its tenants must provide.</p>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="RefreshPartners">
        <span class="oi oi-reload"></span> Refresh
    </button>
</div>

@if (partners == null)
{
    <p><em>Loading partners...</em></p>
}
else if (!partners.Any())
{
    <div class="alert alert-info">No trading partners found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Connection Requirements</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var partner in partners)
                {
                    <tr>
                        <td>@partner.Id</td>
                        <td><code>@partner.Code</code></td>
                        <td>@partner.Name</td>
                        <td>@(partner.Description ?? "-")</td>
                        <td><span class="badge @GetStatusBadgeClass(partner.Status)">@partner.Status</span></td>
                        <td>@partner.ConnectionRequirements.Count</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowEditModal(partner)">
                                <span class="oi oi-pencil"></span> Edit
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showEditModal && selectedPartner != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Trading Partner</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-3">
                        <dt class="col-sm-3">Trading Partner ID</dt>
                        <dd class="col-sm-9">@selectedPartner.Id</dd>
                        <dt class="col-sm-3">Code</dt>
                        <dd class="col-sm-9"><code>@selectedPartner.Code</code></dd>
                        <dt class="col-sm-3">Description</dt>
                        <dd class="col-sm-9">@(selectedPartner.Description ?? "N/A")</dd>
                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9"><span class="badge @GetStatusBadgeClass(selectedPartner.Status)">@selectedPartner.Status</span></dd>
                    </dl>

                    <hr />
                    <h6>Connection Requirements for Tenants</h6>
                    <p class="text-muted small">Field names a tenant must provide when requesting a connection with this partner. PC staff use these to verify with the partner before approving.</p>

                    @for (int i = 0; i < requirements.Count; i++)
                    {
                        var index = i;
                        <div class="input-group mb-2">
                            <input class="form-control" placeholder="Requirement name"
                                   value="@requirements[index]" @onchange="e => requirements[index] = e.Value?.ToString() ?? string.Empty" />
                            <button class="btn btn-outline-danger" type="button" @onclick="() => RemoveRequirement(index)" title="Remove">
                                <span class="oi oi-trash"></span>
                            </button>
                        </div>
                    }
                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="AddRequirement">
                        <span class="oi oi-plus me-1"></span> Add Requirement
                    </button>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveRequirements" disabled="@isSubmitting">
                        @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save Requirements
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TradingPartnerDto>? partners;
    private TradingPartnerDto? selectedPartner;
    private List<string> requirements = new();
    private bool showEditModal;
    private bool isSubmitting;

    protected override async Task OnInitializedAsync() => await RefreshPartners();

    private async Task RefreshPartners() => partners = await Api.GetTradingPartnersAsync();

    private void ShowEditModal(TradingPartnerDto partner)
    {
        selectedPartner = partner;
        requirements = new List<string>(partner.ConnectionRequirements);
        showEditModal = true;
    }

    private void CloseModal()
    {
        showEditModal = false;
        selectedPartner = null;
    }

    private void AddRequirement() => requirements.Add(string.Empty);
    private void RemoveRequirement(int index) => requirements.RemoveAt(index);

    private async Task SaveRequirements()
    {
        if (selectedPartner == null) return;
        isSubmitting = true;
        try
        {
            var cleaned = requirements
                .Select(r => r?.Trim() ?? string.Empty)
                .Where(r => r.Length > 0)
                .ToList();

            if (await Api.UpdatePartnerConnectionRequirementsAsync(selectedPartner.Id, cleaned))
            {
                CloseModal();
                await RefreshPartners();
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private string GetStatusBadgeClass(string status) => status?.ToLower() switch
    {
        "active" => "bg-success",
        "inactive" => "bg-secondary",
        "pending" => "bg-warning",
        _ => "bg-info"
    };
}
