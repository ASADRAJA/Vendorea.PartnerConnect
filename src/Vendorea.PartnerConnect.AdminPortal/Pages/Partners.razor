@page "/partners"
@inject ApiClient Api

<PageTitle>Trading Partners - PartnerConnect Admin</PageTitle>

<h1>Trading Partners</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="RefreshPartners">
        <span class="oi oi-reload"></span> Refresh
    </button>
</div>

@if (partners == null)
{
    <p><em>Loading partners...</em></p>
}
else if (!partners.Any())
{
    <div class="alert alert-info">
        No trading partners found. Use the API to create partners.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var partner in partners)
                {
                    <tr>
                        <td>@partner.Id</td>
                        <td><code>@partner.Code</code></td>
                        <td>@partner.Name</td>
                        <td>@(partner.Description ?? "-")</td>
                        <td>
                            <span class="badge @GetStatusBadgeClass(partner.Status)">@partner.Status</span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-info" @onclick="() => ViewPartner(partner)">
                                View
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (selectedPartner != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Partner Details</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@selectedPartner.Id</dd>
                        <dt class="col-sm-4">Code</dt>
                        <dd class="col-sm-8"><code>@selectedPartner.Code</code></dd>
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@selectedPartner.Name</dd>
                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@(selectedPartner.Description ?? "N/A")</dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge @GetStatusBadgeClass(selectedPartner.Status)">@selectedPartner.Status</span>
                        </dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TradingPartnerDto>? partners;
    private TradingPartnerDto? selectedPartner;

    protected override async Task OnInitializedAsync()
    {
        await RefreshPartners();
    }

    private async Task RefreshPartners()
    {
        partners = await Api.GetTradingPartnersAsync();
    }

    private void ViewPartner(TradingPartnerDto partner)
    {
        selectedPartner = partner;
    }

    private void CloseModal()
    {
        selectedPartner = null;
    }

    private string GetStatusBadgeClass(string status) => status?.ToLower() switch
    {
        "active" => "bg-success",
        "inactive" => "bg-secondary",
        "pending" => "bg-warning",
        _ => "bg-info"
    };
}
