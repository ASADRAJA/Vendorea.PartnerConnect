@page "/cron-jobs"
@inject ApiClient Api

<PageTitle>Cron Jobs - PartnerConnect Admin</PageTitle>

<h1>Cron Jobs</h1>
<p class="text-muted">Scheduled background jobs. Edit a job's schedule, enable/disable it, run it on demand, and review run history.</p>

<div class="mb-3">
    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadJobs">
        <span class="oi oi-reload me-1"></span> Refresh
    </button>
</div>

@if (jobs == null)
{
    <p><em>Loading jobs...</em></p>
}
else if (!jobs.Any())
{
    <div class="alert alert-info">No scheduled jobs are registered yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Job</th>
                    <th>Schedule</th>
                    <th>Enabled</th>
                    <th>Last Run</th>
                    <th>Next Run (UTC)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in jobs)
                {
                    <tr>
                        <td>
                            <strong>@job.DisplayName</strong><br />
                            <code class="small">@job.JobKey</code>
                            @if (!string.IsNullOrEmpty(job.Description))
                            {
                                <div class="text-muted small">@job.Description</div>
                            }
                        </td>
                        <td>
                            <code>@job.CronExpression</code><br />
                            <span class="text-muted small">@job.TimeZoneId</span>
                        </td>
                        <td>
                            @if (job.IsEnabled)
                            {
                                <span class="badge bg-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                        </td>
                        <td>
                            @if (job.LastRunAt is null)
                            {
                                <span class="text-muted">Never</span>
                            }
                            else
                            {
                                <span class="badge @LastRunBadge(job.LastRunStatus)">@job.LastRunStatus</span>
                                <div class="text-muted small">@job.LastRunAt?.ToLocalTime().ToString("g")</div>
                            }
                        </td>
                        <td>
                            <span class="small">@(job.IsEnabled ? job.NextDueAt?.ToString("g") ?? "—" : "—")</span>
                        </td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowEditModal(job)" title="Edit schedule">
                                <span class="oi oi-pencil"></span>
                            </button>
                            <button class="btn btn-sm btn-outline-success" @onclick="() => RunNow(job)" disabled="@(runningJobId == job.Id)" title="Run now">
                                @if (runningJobId == job.Id) { <span class="spinner-border spinner-border-sm"></span> } else { <span class="oi oi-media-play"></span> }
                            </button>
                            <button class="btn btn-sm btn-outline-info" @onclick="() => ShowHistory(job)" title="Run history">
                                <span class="oi oi-clock"></span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (runMessage != null)
{
    <div class="alert @(runMessageSuccess ? "alert-success" : "alert-danger") alert-dismissible">
        @runMessage
        <button type="button" class="btn-close" @onclick="() => runMessage = null"></button>
    </div>
}

@* Edit modal *@
@if (showEditModal && editJob != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Job — @editJob.DisplayName</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="enabled" @bind="editEnabled" />
                        <label class="form-check-label" for="enabled">Enabled</label>
                    </div>
                    <div class="row">
                        <div class="col-md-7 mb-3">
                            <label class="form-label">Cron expression</label>
                            <input class="form-control" @bind="editCron" placeholder="0 6 * * *" />
                            <small class="text-muted">Standard 5-field (min hour day month weekday) or 6-field with seconds.</small>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Time zone</label>
                            <input class="form-control" @bind="editTimeZone" placeholder="UTC" />
                            <small class="text-muted">e.g. UTC or America/New_York</small>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary mb-2" type="button" @onclick="PreviewCron">
                        <span class="oi oi-eye me-1"></span> Preview next runs
                    </button>
                    @if (cronPreview != null)
                    {
                        @if (!cronPreview.IsValid)
                        {
                            <div class="alert alert-danger py-2">Invalid cron: @cronPreview.Error</div>
                        }
                        else
                        {
                            <ul class="small">
                                @foreach (var t in cronPreview.NextRunsUtc)
                                {
                                    <li>@t.ToString("ddd, dd MMM yyyy HH:mm 'UTC'")</li>
                                }
                            </ul>
                        }
                    }
                    <div class="mb-3">
                        <label class="form-label">Configuration (JSON)</label>
                        <textarea class="form-control font-monospace" rows="6" @bind="editConfigJson"
                                  placeholder="Job-specific settings as JSON"></textarea>
                        <small class="text-muted">Job-specific settings (e.g. FTP host/credentials/file name for the SPR inventory job).</small>
                    </div>
                    @if (editError != null)
                    {
                        <div class="alert alert-danger py-2">@editError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveJob" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* History modal *@
@if (showHistoryModal && historyJob != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Run History — @historyJob.DisplayName</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    @if (runs == null)
                    {
                        <p><em>Loading...</em></p>
                    }
                    else if (!runs.Any())
                    {
                        <p class="text-muted">No runs recorded yet.</p>
                    }
                    else
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr><th>Started</th><th>Status</th><th>Trigger</th><th>Detail</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var r in runs)
                                {
                                    <tr>
                                        <td class="small">@r.StartedAt.ToLocalTime().ToString("g")</td>
                                        <td><span class="badge @LastRunBadge(r.Status)">@r.Status</span></td>
                                        <td class="small">@r.TriggeredBy</td>
                                        <td class="small">@(r.ErrorMessage ?? r.Detail ?? "")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ScheduledJobDto>? jobs;
    private int? runningJobId;
    private string? runMessage;
    private bool runMessageSuccess;

    // Edit modal state
    private bool showEditModal;
    private ScheduledJobDto? editJob;
    private string editCron = "";
    private string editTimeZone = "UTC";
    private bool editEnabled;
    private string? editConfigJson;
    private CronPreviewResponse? cronPreview;
    private string? editError;
    private bool isSaving;

    // History modal state
    private bool showHistoryModal;
    private ScheduledJobDto? historyJob;
    private List<ScheduledJobRunDto>? runs;

    protected override async Task OnInitializedAsync() => await LoadJobs();

    private async Task LoadJobs() => jobs = await Api.GetScheduledJobsAsync();

    private void ShowEditModal(ScheduledJobDto job)
    {
        editJob = job;
        editCron = job.CronExpression;
        editTimeZone = job.TimeZoneId;
        editEnabled = job.IsEnabled;
        editConfigJson = job.ConfigJson;
        cronPreview = null;
        editError = null;
        showEditModal = true;
    }

    private async Task PreviewCron()
    {
        cronPreview = await Api.PreviewCronAsync(new CronPreviewRequest
        {
            CronExpression = editCron,
            TimeZoneId = editTimeZone,
            Count = 5
        });
    }

    private async Task SaveJob()
    {
        if (editJob == null) return;
        isSaving = true;
        editError = null;
        try
        {
            var (ok, error) = await Api.UpdateScheduledJobAsync(editJob.Id, new UpdateScheduledJobRequest
            {
                CronExpression = editCron,
                TimeZoneId = editTimeZone,
                IsEnabled = editEnabled,
                ConfigJson = string.IsNullOrWhiteSpace(editConfigJson) ? null : editConfigJson
            });
            if (ok)
            {
                CloseModals();
                await LoadJobs();
            }
            else
            {
                editError = error;
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task RunNow(ScheduledJobDto job)
    {
        runningJobId = job.Id;
        runMessage = null;
        try
        {
            var result = await Api.RunScheduledJobAsync(job.Id);
            runMessageSuccess = result?.Success ?? false;
            runMessage = runMessageSuccess
                ? $"{job.DisplayName}: {result?.Detail ?? "completed"}"
                : $"{job.DisplayName} failed: {result?.Error ?? "unknown error"}";
            await LoadJobs();
        }
        finally
        {
            runningJobId = null;
        }
    }

    private async Task ShowHistory(ScheduledJobDto job)
    {
        historyJob = job;
        runs = null;
        showHistoryModal = true;
        runs = await Api.GetScheduledJobRunsAsync(job.Id, 25);
    }

    private void CloseModals()
    {
        showEditModal = false;
        showHistoryModal = false;
        editJob = null;
        historyJob = null;
        runs = null;
    }

    private static string LastRunBadge(string? status) => status switch
    {
        "Succeeded" => "bg-success",
        "Failed" => "bg-danger",
        "Running" => "bg-info",
        _ => "bg-secondary"
    };
}
