@page "/onboard-organization"
@attribute [Authorize(Roles = "Admin,Support")]
@inject ApiClient Api

<PageTitle>Onboard Organization - PartnerConnect Admin</PageTitle>

<h1>Onboard Organization</h1>
<p class="text-muted">
    Create an organization and stand it up in one step: it is activated immediately, its plan
    subscription is created, and an activation invite is emailed to the first admin. Use this for
    operator-led onboarding instead of waiting for a self-service registration.
</p>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(succeeded ? "alert-success" : "alert-danger") alert-dismissible" role="alert">
        @message
        <button type="button" class="btn-close" @onclick="() => message = null"></button>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <span class="oi oi-plus me-1"></span> New Organization
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Organization Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" @bind="form.OrganizationName" placeholder="e.g., Acme Corporation" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Billing Plan <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="form.PlanCode">
                        <option value="">Select a plan...</option>
                        @foreach (var plan in billingPlans)
                        {
                            <option value="@plan.Code">@plan.Name (@plan.Code) - @plan.MonthlyPrice.ToString("C")/mo</option>
                        }
                    </select>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Admin Display Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="form.AdminDisplayName" placeholder="e.g., Jane Smith" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Admin Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" @bind="form.AdminEmail" placeholder="admin@example.com" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Contact Phone</label>
                    <input type="text" class="form-control" @bind="form.ContactPhone" placeholder="Optional" />
                </div>

                <div class="d-flex justify-content-end">
                    <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@(!CanSubmit || isSubmitting)">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <span class="oi oi-check me-1"></span> Create &amp; Invite Admin
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private OnboardOrganizationRequest form = new();
    private List<BillingPlanDto> billingPlans = new();

    private bool isSubmitting;
    private string? message;
    private bool succeeded;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(form.OrganizationName)
        && !string.IsNullOrWhiteSpace(form.PlanCode)
        && !string.IsNullOrWhiteSpace(form.AdminDisplayName)
        && !string.IsNullOrWhiteSpace(form.AdminEmail);

    protected override async Task OnInitializedAsync()
    {
        billingPlans = await Api.GetBillingPlansAsync();
    }

    private async Task SubmitAsync()
    {
        if (!CanSubmit)
            return;

        isSubmitting = true;
        message = null;
        StateHasChanged();
        try
        {
            var (result, error) = await Api.OnboardOrganizationAsync(form);
            if (result is not null)
            {
                succeeded = true;
                message = $"Organization created — an activation invite was emailed to {result.InvitedAdminEmail}.";
                form = new OnboardOrganizationRequest();
            }
            else
            {
                succeeded = false;
                message = error ?? "Failed to onboard the organization.";
            }
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }
}
