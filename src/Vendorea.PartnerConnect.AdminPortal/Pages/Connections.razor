@page "/connections"
@inject ApiClient Api

<PageTitle>Connections - PartnerConnect Admin</PageTitle>

<h1>Dealer-Partner Connections</h1>

<div class="row mb-3">
    <div class="col-md-3">
        <label class="form-label">Filter by Dealer</label>
        <select class="form-select" value="@selectedDealerId" @onchange="OnDealerFilterChanged">
            <option value="">All Dealers</option>
            @foreach (var dealer in dealers)
            {
                <option value="@dealer.Key">@dealer.Value</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Filter by Partner</label>
        <select class="form-select" value="@selectedPartnerId" @onchange="OnPartnerFilterChanged">
            <option value="">All Partners</option>
            @foreach (var partner in partners)
            {
                <option value="@partner.Key">@partner.Value</option>
            }
        </select>
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-primary me-2" @onclick="RefreshConnections">
            <span class="oi oi-reload"></span> Refresh
        </button>
        <button class="btn btn-outline-secondary" @onclick="ClearFilters">
            Clear Filters
        </button>
    </div>
</div>

@if (connections == null)
{
    <p><em>Loading connections...</em></p>
}
else if (!connections.Any())
{
    <div class="alert alert-info">
        No connections found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Dealer</th>
                    <th>Partner</th>
                    <th>Status</th>
                    <th>Last Successful Sync</th>
                    <th>Last Sync Attempt</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var conn in connections)
                {
                    <tr>
                        <td>@conn.Id</td>
                        <td>@(conn.DealerName ?? $"Dealer #{conn.DealerId}")</td>
                        <td>@(conn.PartnerName ?? $"Partner #{conn.TradingPartnerId}")</td>
                        <td>
                            <span class="badge @(conn.IsActive ? "bg-success" : "bg-secondary")">
                                @(conn.Status ?? (conn.IsActive ? "Active" : "Inactive"))
                            </span>
                        </td>
                        <td>@(conn.LastSuccessfulSync?.ToLocalTime().ToString("g") ?? "Never")</td>
                        <td>@(conn.LastSyncAttempt?.ToLocalTime().ToString("g") ?? "Never")</td>
                        <td>@conn.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td>
                            @if (conn.IsActive)
                            {
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => DeactivateConnection(conn.Id)">
                                    Deactivate
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success" @onclick="() => ActivateConnection(conn.Id)">
                                    Activate
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
        @message
        <button type="button" class="btn-close" @onclick="() => message = null"></button>
    </div>
}

@code {
    private List<ConnectionDto>? allConnections;
    private List<ConnectionDto>? connections;
    private string? message;
    private bool isError;
    private string? selectedDealerId;
    private string? selectedPartnerId;
    private Dictionary<int, string> dealers = new();
    private Dictionary<int, string> partners = new();

    protected override async Task OnInitializedAsync()
    {
        await RefreshConnections();
    }

    private async Task RefreshConnections()
    {
        allConnections = await Api.GetConnectionsAsync();

        // Build filter options from the data
        dealers = allConnections
            .GroupBy(c => c.DealerId)
            .ToDictionary(g => g.Key, g => g.First().DealerName ?? $"Dealer #{g.Key}");

        partners = allConnections
            .Where(c => c.TradingPartnerId > 0)
            .GroupBy(c => c.TradingPartnerId)
            .ToDictionary(g => g.Key, g => g.First().PartnerName ?? $"Partner #{g.Key}");

        ApplyFilters();
    }

    private void ApplyFilters()
    {
        if (allConnections == null)
        {
            connections = null;
            return;
        }

        var filtered = allConnections.AsEnumerable();

        if (!string.IsNullOrEmpty(selectedDealerId) && int.TryParse(selectedDealerId, out var dealerId))
        {
            filtered = filtered.Where(c => c.DealerId == dealerId);
        }

        if (!string.IsNullOrEmpty(selectedPartnerId) && int.TryParse(selectedPartnerId, out var partnerId))
        {
            filtered = filtered.Where(c => c.TradingPartnerId == partnerId);
        }

        connections = filtered.ToList();
    }

    private void ClearFilters()
    {
        selectedDealerId = null;
        selectedPartnerId = null;
        ApplyFilters();
    }

    private void OnDealerFilterChanged(ChangeEventArgs e)
    {
        selectedDealerId = e.Value?.ToString();
        ApplyFilters();
    }

    private void OnPartnerFilterChanged(ChangeEventArgs e)
    {
        selectedPartnerId = e.Value?.ToString();
        ApplyFilters();
    }

    private async Task ActivateConnection(int id)
    {
        var success = await Api.ActivateConnectionAsync(id);
        if (success)
        {
            message = $"Connection {id} activated successfully.";
            isError = false;
            await RefreshConnections();
        }
        else
        {
            message = $"Failed to activate connection {id}.";
            isError = true;
        }
    }

    private async Task DeactivateConnection(int id)
    {
        var success = await Api.DeactivateConnectionAsync(id);
        if (success)
        {
            message = $"Connection {id} deactivated successfully.";
            isError = false;
            await RefreshConnections();
        }
        else
        {
            message = $"Failed to deactivate connection {id}.";
            isError = true;
        }
    }
}
