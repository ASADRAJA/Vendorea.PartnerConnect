@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model Vendorea.PartnerConnect.AdminPortal.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — PartnerConnect Admin</title>
    <base href="~/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container" style="max-width: 420px; margin-top: 8rem;">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title mb-1 text-center">PartnerConnect Admin</h4>
                <p class="text-muted text-center mb-4" style="font-size: 0.9rem;">Sign in to continue</p>

                @if (!string.IsNullOrEmpty(Model.Error))
                {
                    <div class="alert alert-danger py-2">@Model.Error</div>
                }

                <form method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div class="mb-3">
                        <label class="form-label" asp-for="Username">Username</label>
                        <input class="form-control" asp-for="Username" autofocus autocomplete="username" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label" asp-for="Password">Password</label>
                        <input type="password" class="form-control" asp-for="Password" autocomplete="current-password" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Sign in</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
