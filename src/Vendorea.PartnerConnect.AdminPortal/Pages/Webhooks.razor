@page "/webhooks"
@inject ApiClient Api

<PageTitle>Webhooks - PartnerConnect Admin</PageTitle>

<h1>Webhook Subscriptions</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="RefreshWebhooks">
        <span class="oi oi-reload"></span> Refresh
    </button>
</div>

@if (webhooks == null)
{
    <p><em>Loading webhooks...</em></p>
}
else if (!webhooks.Any())
{
    <div class="alert alert-info">
        No webhook subscriptions found. Use the API to create webhooks.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>URL</th>
                    <th>Events</th>
                    <th>Status</th>
                    <th>Deliveries</th>
                    <th>Last Delivery</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var webhook in webhooks)
                {
                    <tr>
                        <td>@webhook.Id</td>
                        <td>@webhook.Name</td>
                        <td><small><code>@webhook.Url</code></small></td>
                        <td>
                            @foreach (var evt in webhook.EventTypes.Take(2))
                            {
                                <span class="badge bg-info me-1">@evt</span>
                            }
                            @if (webhook.EventTypes.Count > 2)
                            {
                                <span class="badge bg-secondary">+@(webhook.EventTypes.Count - 2) more</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(webhook.IsEnabled ? "bg-success" : "bg-secondary")">
                                @(webhook.IsEnabled ? "Enabled" : "Disabled")
                            </span>
                        </td>
                        <td>
                            <span class="text-success">@webhook.SuccessfulDeliveries</span> /
                            <span class="text-danger">@webhook.FailedDeliveries</span>
                        </td>
                        <td>@(webhook.LastDeliveryAt?.ToLocalTime().ToString("g") ?? "Never")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<WebhookSubscriptionDto>? webhooks;

    protected override async Task OnInitializedAsync()
    {
        await RefreshWebhooks();
    }

    private async Task RefreshWebhooks()
    {
        webhooks = await Api.GetWebhookSubscriptionsAsync();
    }
}
