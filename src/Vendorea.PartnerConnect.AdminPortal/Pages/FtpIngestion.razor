@page "/ftp-ingestion"
@using Vendorea.PartnerConnect.AdminPortal.Models
@using Vendorea.PartnerConnect.AdminPortal.Services
@implements IDisposable
@inject ApiClient Api
@inject IJSRuntime JS

<PageTitle>Content Ingestion - PartnerConnect Admin</PageTitle>

<h1>Partner Content Ingestion</h1>
<p class="text-muted">Configure and manage automated content ingestion from trading partners.</p>

<div class="row mb-4">
    <div class="col-md-4">
        <label class="form-label"><strong>Select Trading Partner</strong></label>
        <select class="form-select" value="@selectedPartner" @onchange="OnPartnerChanged">
            <option value="">-- Select Partner --</option>
            @foreach (var partner in availablePartners)
            {
                <option value="@partner.Code">@partner.Name</option>
            }
        </select>
    </div>
</div>

@if (string.IsNullOrEmpty(selectedPartner))
{
    <div class="alert alert-info">
        <span class="oi oi-info me-2"></span>
        Select a trading partner above to configure content ingestion settings.
    </div>
}
else if (selectedPartner == "SPR")
{
    <!-- SPR (Etilize) Content Ingestion Configuration -->
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <span class="oi oi-cog me-2"></span> SPR (Etilize) FTP Connection Settings
                </div>
                <div class="card-body">
                    @if (isLoadingConfig)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary"></div>
                            <p class="mt-2">Loading configuration...</p>
                        </div>
                    }
                    else if (config == null)
                    {
                        <div class="alert alert-warning">
                            Failed to load configuration. <button class="btn btn-link p-0" @onclick="LoadConfig">Retry</button>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">FTP Host</label>
                                <input type="text" class="form-control" @bind="config.FtpHost" placeholder="ftp.etilize.com" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">FTP Port</label>
                                <input type="number" class="form-control" @bind="config.FtpPort" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Connection Timeout (sec)</label>
                                <input type="number" class="form-control" @bind="config.ConnectionTimeoutSeconds" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">FTP Username</label>
                                <input type="text" class="form-control" @bind="config.FtpUsername" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">FTP Password</label>
                                <div class="input-group">
                                    <input type="@(showPassword ? "text" : "password")" class="form-control" @bind="config.FtpPassword" />
                                    <button class="btn btn-outline-secondary" type="button" @onclick="() => showPassword = !showPassword">
                                        <span class="oi @(showPassword ? "oi-eye-closed" : "oi-eye")"></span>
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Local Download Path</label>
                                <input type="text" class="form-control" @bind="config.LocalDownloadPath" placeholder="C:\inquire" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Locale</label>
                                <select class="form-select" @bind="config.Locale">
                                    <option value="EN_US">EN_US (English US)</option>
                                    <option value="EN_CA">EN_CA (English Canada)</option>
                                    <option value="ES_US">ES_US (Spanish US)</option>
                                    <option value="FR_CA">FR_CA (French Canada)</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Database Type</label>
                                <select class="form-select" @bind="config.DatabaseType">
                                    <option value="mssql">MS SQL Server</option>
                                    <option value="oracle">Oracle</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h6>Import Options</h6>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Bulk Insert Batch Size</label>
                                <input type="number" class="form-control" @bind="config.BulkInsertBatchSize" />
                            </div>
                            <div class="col-md-4">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" @bind="config.CleanupAfterImport" id="cleanupCheck" />
                                    <label class="form-check-label" for="cleanupCheck">
                                        Cleanup downloaded files after import
                                    </label>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h6>Schedule Settings</h6>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" @bind="config.Enabled" id="enabledCheck" />
                                    <label class="form-check-label" for="enabledCheck">
                                        <strong>Enable Ingestion</strong>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" @bind="config.EnableScheduledRun" id="scheduleCheck" />
                                    <label class="form-check-label" for="scheduleCheck">
                                        Enable Scheduled Run
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Run Hour (UTC)</label>
                                <select class="form-select" @bind="config.ScheduledRunHourUtc" disabled="@(!config.EnableScheduledRun)">
                                    @for (int h = 0; h < 24; h++)
                                    {
                                        <option value="@h">@h.ToString("00"):00 UTC</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Check Interval (min)</label>
                                <input type="number" class="form-control" @bind="config.CheckIntervalMinutes" min="1" />
                            </div>
                        </div>

                        <div class="mt-4">
                            <button class="btn btn-primary" @onclick="SaveConfig" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <span class="oi oi-check me-1"></span> Save Configuration
                            </button>
                            <button class="btn btn-outline-secondary ms-2" @onclick="TestConnection" disabled="@isTesting">
                                @if (isTesting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <span class="oi oi-pulse me-1"></span> Test Connection
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(saveMessage))
                        {
                            <div class="alert @(saveSuccess ? "alert-success" : "alert-danger") mt-3">
                                @saveMessage
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <span class="oi oi-media-play me-2"></span> Manual Import
                </div>
                <div class="card-body">
                    <p class="text-muted small">Run the ingestion pipeline manually without waiting for the scheduled time.</p>

                    <button class="btn btn-success w-100" @onclick="RunImportNowWithPolling" disabled="@isRunning">
                        @if (isRunning)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Running...</span>
                        }
                        else
                        {
                            <span class="oi oi-cloud-download me-1"></span>
                            <span>Run Import Now</span>
                        }
                    </button>

                    @if (runResult != null)
                    {
                        <div class="mt-3">
                            @if (runResult.Success)
                            {
                                <div class="alert alert-success small">
                                    <strong>Import completed successfully!</strong>
                                    <ul class="mb-0 mt-2">
                                        <li>Products: @runResult.ProductsTransformed.ToString("N0")</li>
                                        <li>Categories: @runResult.CategoriesTransformed.ToString("N0")</li>
                                        <li>Features: @runResult.FeaturesTransformed.ToString("N0")</li>
                                        <li>Duration: @runResult.Duration</li>
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-danger small">
                                    <strong>Import failed!</strong>
                                    @if (runResult.Errors.Any())
                                    {
                                        <ul class="mb-0 mt-2">
                                            @foreach (var error in runResult.Errors.Take(5))
                                            {
                                                <li>@error</li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <span class="oi oi-info me-2"></span> Current Status
                </div>
                <div class="card-body">
                    @if (status != null)
                    {
                        <dl class="mb-0">
                            <dt>Worker Status</dt>
                            <dd>
                                @if (status.IsRunning)
                                {
                                    <span class="badge bg-primary">
                                        <span class="spinner-border spinner-border-sm me-1" style="width: 0.7rem; height: 0.7rem;"></span>
                                        @(status.CurrentPhase ?? "Running")
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Idle</span>
                                }
                            </dd>
                            <dt>Last Run</dt>
                            <dd>@(status.LastRunAt?.ToLocalTime().ToString("g") ?? "Never")</dd>
                            <dt>Last Result</dt>
                            <dd>
                                @if (status.LastRunSuccess.HasValue)
                                {
                                    <span class="badge @(status.LastRunSuccess.Value ? "bg-success" : "bg-danger")">
                                        @(status.LastRunSuccess.Value ? "Success" : "Failed")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </dd>
                            <dt>Next Scheduled Run</dt>
                            <dd>@(status.NextScheduledRun?.ToLocalTime().ToString("g") ?? "Not scheduled")</dd>
                        </dl>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Loading status...</p>
                    }
                    <button class="btn btn-sm btn-outline-primary mt-2" @onclick="LoadStatus">
                        <span class="oi oi-reload"></span> Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><span class="oi oi-clock me-2"></span> SPR Import History</span>
                    <button class="btn btn-sm btn-outline-primary" @onclick="LoadHistory">
                        <span class="oi oi-reload"></span> Refresh
                    </button>
                </div>
                <div class="card-body">
                    @if (isLoadingHistory)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary"></div>
                        </div>
                    }
                    else if (importHistory.Count == 0)
                    {
                        <p class="text-muted text-center py-4">No import history found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-sm">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Started</th>
                                        <th>Completed</th>
                                        <th>Duration</th>
                                        <th>Status</th>
                                        <th>Products</th>
                                        <th>Categories</th>
                                        <th>Features</th>
                                        <th>Relationships</th>
                                        <th>Errors</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var run in importHistory)
                                    {
                                        <tr>
                                            <td>@run.Id</td>
                                            <td>@run.StartedAt.ToLocalTime().ToString("g")</td>
                                            <td>@(run.CompletedAt?.ToLocalTime().ToString("g") ?? "-")</td>
                                            <td>@run.Duration</td>
                                            <td>
                                                <span class="badge @GetStatusBadgeClass(run.Status)">
                                                    @if (run.Status == "Downloading" || run.Status == "Importing" || run.Status == "Transforming")
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-1" style="width: 0.6rem; height: 0.6rem;"></span>
                                                    }
                                                    @run.Status
                                                </span>
                                            </td>
                                            <td>@run.ProductsTransformed.ToString("N0")</td>
                                            <td>@run.CategoriesTransformed.ToString("N0")</td>
                                            <td>@run.FeaturesTransformed.ToString("N0")</td>
                                            <td>@run.RelationshipsTransformed.ToString("N0")</td>
                                            <td>
                                                @if (run.Errors.Any())
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowErrors(run)">
                                                        @run.Errors.Count errors
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Placeholder for other partners -->
    <div class="alert alert-secondary">
        <h5 class="alert-heading">
            <span class="oi oi-wrench me-2"></span>
            @GetPartnerName(selectedPartner) Content Ingestion
        </h5>
        <hr />
        <p class="mb-0">
            Content ingestion configuration for <strong>@GetPartnerName(selectedPartner)</strong> is not yet available.
            This feature will be implemented in a future release.
        </p>
    </div>
}

@if (selectedRun != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Import Errors - Run #@selectedRun.Id</h5>
                    <button type="button" class="btn-close" @onclick="() => selectedRun = null"></button>
                </div>
                <div class="modal-body">
                    <ul class="text-danger small">
                        @foreach (var error in selectedRun.Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => selectedRun = null">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string selectedPartner = "";

    private List<PartnerOption> availablePartners = new()
    {
        new PartnerOption { Code = "SPR", Name = "SPR (S.P. Richards / Etilize)" },
        new PartnerOption { Code = "UNI", Name = "United Stationers" },
        new PartnerOption { Code = "ESS", Name = "Essendant" },
        new PartnerOption { Code = "GEN", Name = "Genuine Parts Company" }
    };

    private FtpIngestionConfigDto? config;
    private FtpIngestionStatusDto? status;
    private List<FtpIngestionRunDto> importHistory = new();
    private FtpIngestionRunDto? runResult;
    private FtpIngestionRunDto? selectedRun;

    private bool isLoadingConfig;
    private bool isLoadingHistory;
    private bool isSaving;
    private bool isTesting;
    private bool isRunning;
    private bool showPassword;

    private string? saveMessage;
    private bool saveSuccess;

    protected override Task OnInitializedAsync()
    {
        // Don't load SPR data until SPR is selected
        return Task.CompletedTask;
    }

    private async Task OnPartnerChanged(ChangeEventArgs e)
    {
        selectedPartner = e.Value?.ToString() ?? "";

        // Reset state when changing partners
        config = null;
        status = null;
        importHistory.Clear();
        runResult = null;
        saveMessage = null;

        // Load data for the selected partner
        if (selectedPartner == "SPR")
        {
            await LoadSprData();
        }
    }

    private async Task LoadSprData()
    {
        await Task.WhenAll(
            LoadConfig(),
            LoadStatus(),
            LoadHistory()
        );
    }

    private async Task LoadConfig()
    {
        isLoadingConfig = true;
        try
        {
            config = await Api.GetFtpIngestionConfigAsync();
        }
        finally
        {
            isLoadingConfig = false;
        }
    }

    private async Task LoadStatus()
    {
        status = await Api.GetFtpIngestionStatusAsync();
    }

    private async Task LoadHistory()
    {
        isLoadingHistory = true;
        try
        {
            importHistory = await Api.GetFtpIngestionHistoryAsync();
        }
        finally
        {
            isLoadingHistory = false;
        }
    }

    private async Task SaveConfig()
    {
        if (config == null) return;

        isSaving = true;
        saveMessage = null;

        try
        {
            var success = await Api.SaveFtpIngestionConfigAsync(config);
            saveSuccess = success;
            saveMessage = success ? "Configuration saved successfully!" : "Failed to save configuration.";
        }
        catch (Exception ex)
        {
            saveSuccess = false;
            saveMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task TestConnection()
    {
        if (config == null) return;

        isTesting = true;
        saveMessage = null;

        try
        {
            var result = await Api.TestFtpConnectionAsync(config);
            saveSuccess = result.Success;
            saveMessage = result.Success
                ? $"Connection successful! Found {result.FilesFound} files."
                : $"Connection failed: {result.ErrorMessage}";
        }
        catch (Exception ex)
        {
            saveSuccess = false;
            saveMessage = $"Test failed: {ex.Message}";
        }
        finally
        {
            isTesting = false;
        }
    }

    private async Task RunImportNow()
    {
        isRunning = true;
        runResult = null;

        try
        {
            runResult = await Api.RunFtpIngestionAsync();
            await LoadHistory();
            await LoadStatus();
        }
        catch (Exception ex)
        {
            runResult = new FtpIngestionRunDto
            {
                Success = false,
                Errors = new List<string> { ex.Message }
            };
        }
        finally
        {
            isRunning = false;
        }
    }

    private void ShowErrors(FtpIngestionRunDto run)
    {
        selectedRun = run;
    }

    private string GetPartnerName(string code)
    {
        return availablePartners.FirstOrDefault(p => p.Code == code)?.Name ?? code;
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Completed" => "bg-success",
            "Failed" => "bg-danger",
            "Downloading" => "bg-info",
            "Importing" => "bg-info",
            "Transforming" => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }

    private System.Threading.Timer? _pollingTimer;

    private async Task RunImportNowWithPolling()
    {
        isRunning = true;
        runResult = null;

        try
        {
            // Start the import (returns immediately now)
            runResult = await Api.RunFtpIngestionAsync();

            // Start polling for updates every 5 seconds
            _pollingTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadStatus();
                    await LoadHistory();
                    StateHasChanged();

                    // Stop polling when no longer running
                    if (status != null && !status.IsRunning)
                    {
                        _pollingTimer?.Dispose();
                        _pollingTimer = null;
                        isRunning = false;

                        // Get final result
                        if (importHistory.Count > 0)
                        {
                            runResult = importHistory[0];
                        }
                        StateHasChanged();
                    }
                });
            }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5));
        }
        catch (Exception ex)
        {
            runResult = new FtpIngestionRunDto
            {
                Success = false,
                Errors = new List<string> { ex.Message }
            };
            isRunning = false;
        }
    }

    public void Dispose()
    {
        _pollingTimer?.Dispose();
    }

    private class PartnerOption
    {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
    }
}
