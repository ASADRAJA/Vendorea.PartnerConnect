@page "/organizations"
@inject ApiClient Api

<PageTitle>Organizations - PartnerConnect Admin</PageTitle>

<h1>Organizations</h1>
<p class="text-muted">Register and manage organizations. Tenants are provisioned by the connections workflow.</p>

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <ul class="nav nav-tabs card-header-tabs">
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "active" ? "active" : "")" @onclick='() => SetTab("active")'>
                            <span class="oi oi-check me-1"></span> Active
                            <span class="badge bg-success ms-1">@orgResult.ActiveCount</span>
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "pending" ? "active" : "")" @onclick='() => SetTab("pending")'>
                            <span class="oi oi-clock me-1"></span> Pending
                            @if (orgResult.PendingCount > 0)
                            {
                                <span class="badge bg-warning text-dark ms-1">@orgResult.PendingCount</span>
                            }
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "all" ? "active" : "")" @onclick='() => SetTab("all")'>
                            <span class="oi oi-list me-1"></span> All
                            <span class="badge bg-secondary ms-1">@orgResult.Total</span>
                        </button>
                    </li>
                </ul>
                <button class="btn btn-primary btn-sm" @onclick="ShowCreateModal">
                    <span class="oi oi-plus me-1"></span> Register Organization
                </button>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadOrganizations">
                            <span class="oi oi-reload me-1"></span> Refresh
                        </button>
                    </div>
                </div>

                @if (isLoading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary"></div>
                        <p class="mt-2">Loading organizations...</p>
                    </div>
                }
                else if (filteredOrganizations.Count == 0)
                {
                    <div class="text-center py-4 text-muted">
                        <span class="oi oi-inbox" style="font-size: 3rem;"></span>
                        <p class="mt-2">No organizations found</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Name</th>
                                    <th>Status</th>
                                    <th>Order Mode</th>
                                    <th>Type</th>
                                    <th>Partners</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var org in filteredOrganizations)
                                {
                                    <tr>
                                        <td><code>@org.Code</code></td>
                                        <td><strong>@org.Name</strong></td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(org.Status)">@org.Status</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">PC Portal</span>
                                            @if (org.ExternalPortalEnabled)
                                            {
                                                <span class="badge bg-info ms-1">External</span>
                                            }
                                        </td>
                                        <td>@(org.IsMultiTenant ? "Multi-Tenant" : "Single")</td>
                                        <td>@org.TradingPartnerIds.Count</td>
                                        <td>@org.CreatedAt.ToLocalTime().ToString("d")</td>
                                        <td>
                                            @if (org.Status == "Pending")
                                            {
                                                <button class="btn btn-sm btn-success me-1" @onclick="() => ApproveOrganization(org.Id)" title="Approve">
                                                    <span class="oi oi-check"></span>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger me-1" @onclick="() => ShowRejectModal(org)" title="Reject">
                                                    <span class="oi oi-x"></span>
                                                </button>
                                            }
                                            else if (org.Status == "Active")
                                            {
                                                <button class="btn btn-sm btn-warning me-1" @onclick="() => SuspendOrganization(org.Id)" title="Suspend">
                                                    <span class="oi oi-ban"></span>
                                                </button>
                                            }
                                            else if (org.Status == "Suspended")
                                            {
                                                <button class="btn btn-sm btn-success me-1" @onclick="() => ApproveOrganization(org.Id)" title="Reactivate">
                                                    <span class="oi oi-action-redo"></span>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditModal(org)" title="Edit">
                                                <span class="oi oi-pencil"></span>
                                            </button>
                                            <a href="/tenants?organizationId=@org.Id" class="btn btn-sm btn-outline-info" title="View Tenants">
                                                <span class="oi oi-people"></span>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* Register / Edit Organization Modal *@
@if (showCreateModal || showEditModal)
{
    var isEdit = showEditModal;
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEdit ? "Edit Organization" : "Register Organization")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    @if (isEdit)
                    {
                        <div class="mb-3">
                            <label class="form-label">Code</label>
                            <input type="text" class="form-control" value="@selectedOrganization?.Code" disabled />
                            <small class="text-muted">System-generated; cannot be changed</small>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light border"><small><span class="oi oi-info me-1"></span> The organization code is generated automatically on save.</small></div>
                    }

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="form.Name" placeholder="e.g., Acme Corporation" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Organization Type</label>
                            <div class="form-check mt-2">
                                <input type="checkbox" class="form-check-input" id="isMultiTenant" @bind="form.IsMultiTenant" disabled="@isEdit" />
                                <label class="form-check-label" for="isMultiTenant">Multi-tenant</label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Contact Email</label>
                            <input type="email" class="form-control" @bind="form.ContactEmail" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Contact Phone</label>
                            <input type="text" class="form-control" @bind="form.ContactPhone" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Billing Plan</label>
                            <select class="form-select" @bind="selectedBillingPlanId">
                                <option value="">Select Billing Plan...</option>
                                @foreach (var plan in billingPlans)
                                {
                                    <option value="@plan.Id">@plan.Name - @plan.MonthlyPrice.ToString("C")/mo</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Payment Terms</label>
                            <select class="form-select" @bind="form.PaymentTerms">
                                @foreach (var term in PaymentTermsOptions)
                                {
                                    <option value="@term">@term</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Trading Partners</label>
                        <div class="border rounded p-2">
                            @if (tradingPartners.Count == 0)
                            {
                                <small class="text-muted">No partners available</small>
                            }
                            else
                            {
                                @foreach (var p in tradingPartners)
                                {
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="partner-@p.Id"
                                               checked="@selectedPartnerIds.Contains(p.Id)"
                                               @onchange="e => TogglePartner(p.Id, e)" />
                                        <label class="form-check-label" for="partner-@p.Id">@p.Name (@p.Code)</label>
                                    </div>
                                }
                            }
                        </div>
                        <small class="text-muted">Partners this organization's tenants may connect to</small>
                    </div>

                    <div class="mb-2 form-check">
                        <input type="checkbox" class="form-check-input" id="externalPortal" @bind="form.ExternalPortalEnabled" />
                        <label class="form-check-label" for="externalPortal">Also integrate via the organization's own external portal</label>
                        <br><small class="text-muted">The PC portal is always available; enable this only if orders flow through the org's portal too.</small>
                    </div>
                    @if (form.ExternalPortalEnabled)
                    {
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Portal Base URL <span class="text-danger">*</span></label>
                                <input type="url" class="form-control" @bind="form.PortalBaseUrl" placeholder="https://..." />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Portal API Key</label>
                                <input type="password" class="form-control" @bind="form.PortalApiKey"
                                       placeholder="@(isEdit && selectedOrganization?.HasPortalApiKey == true ? "•••••• (leave blank to keep)" : "")" />
                                <small class="text-muted">Sent as X-Api-Key when PC calls the org's portal. Stored encrypted.</small>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveOrganization" disabled="@(!CanSave || isSubmitting)">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @(isEdit ? "Save Changes" : "Register")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Reject Modal *@
@if (showRejectModal && selectedOrganization != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Reject @selectedOrganization.Name</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Reason</label>
                    <textarea class="form-control" rows="3" @bind="rejectReason" placeholder="Why is this registration being rejected?"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="RejectOrganization" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Reject
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] PaymentTermsOptions =
        { "CreditCard", "Net15", "Net30", "Net45", "Net60", "Net90" };

    private OrganizationListResult orgResult = new();
    private List<BillingPlanDto> billingPlans = new();
    private List<TradingPartnerDto> tradingPartners = new();

    private string activeTab = "active";
    private bool isLoading = true;
    private bool isSubmitting = false;

    private bool showCreateModal = false;
    private bool showEditModal = false;
    private bool showRejectModal = false;

    private OrganizationDto? selectedOrganization;
    private OrgForm form = new();
    private string selectedBillingPlanId = "";
    private readonly HashSet<int> selectedPartnerIds = new();
    private string? rejectReason;

    private bool CanSave => !string.IsNullOrWhiteSpace(form.Name)
        && (!form.ExternalPortalEnabled || !string.IsNullOrWhiteSpace(form.PortalBaseUrl));

    private List<OrganizationDto> filteredOrganizations => activeTab switch
    {
        "active" => orgResult.Items.Where(o => o.Status == "Active").ToList(),
        "pending" => orgResult.Items.Where(o => o.Status == "Pending").ToList(),
        _ => orgResult.Items
    };

    protected override async Task OnInitializedAsync()
    {
        var orgsTask = LoadOrganizationsAsync();
        var plansTask = Api.GetBillingPlansAsync();
        var partnersTask = Api.GetTradingPartnersAsync();
        await Task.WhenAll(orgsTask, plansTask, partnersTask);
        billingPlans = await plansTask;
        tradingPartners = await partnersTask;
    }

    private async Task LoadOrganizations() => await LoadOrganizationsAsync();

    private async Task LoadOrganizationsAsync()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            orgResult = await Api.GetOrganizationsAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private void ShowCreateModal()
    {
        form = new OrgForm();
        selectedBillingPlanId = "";
        selectedPartnerIds.Clear();
        selectedOrganization = null;
        showCreateModal = true;
    }

    private void ShowEditModal(OrganizationDto org)
    {
        selectedOrganization = org;
        form = new OrgForm
        {
            Name = org.Name,
            ContactEmail = null,
            ContactPhone = null,
            PaymentTerms = org.PaymentTerms,
            IsMultiTenant = org.IsMultiTenant,
            ExternalPortalEnabled = org.ExternalPortalEnabled,
            PortalBaseUrl = org.PortalBaseUrl,
            PortalApiKey = null
        };
        selectedBillingPlanId = org.BillingPlanId?.ToString() ?? "";
        selectedPartnerIds.Clear();
        foreach (var id in org.TradingPartnerIds) selectedPartnerIds.Add(id);
        showEditModal = true;
    }

    private void ShowRejectModal(OrganizationDto org)
    {
        selectedOrganization = org;
        rejectReason = null;
        showRejectModal = true;
    }

    private void CloseModals()
    {
        showCreateModal = false;
        showEditModal = false;
        showRejectModal = false;
        selectedOrganization = null;
    }

    private void TogglePartner(int partnerId, ChangeEventArgs e)
    {
        if (e.Value is bool b && b) selectedPartnerIds.Add(partnerId);
        else selectedPartnerIds.Remove(partnerId);
    }

    private async Task SaveOrganization()
    {
        if (!CanSave) return;
        isSubmitting = true;
        try
        {
            Guid? planId = Guid.TryParse(selectedBillingPlanId, out var pid) ? pid : null;

            if (showEditModal && selectedOrganization != null)
            {
                var req = new UpdateOrganizationRequest
                {
                    Name = form.Name,
                    ContactEmail = form.ContactEmail,
                    ContactPhone = form.ContactPhone,
                    BillingPlanId = planId,
                    PaymentTerms = form.PaymentTerms,
                    ExternalPortalEnabled = form.ExternalPortalEnabled,
                    PortalBaseUrl = form.PortalBaseUrl,
                    PortalApiKey = string.IsNullOrEmpty(form.PortalApiKey) ? null : form.PortalApiKey,
                    TradingPartnerIds = selectedPartnerIds.ToList()
                };
                if (await Api.UpdateOrganizationAsync(selectedOrganization.Id, req))
                {
                    CloseModals();
                    await LoadOrganizations();
                }
            }
            else
            {
                var req = new CreateOrganizationRequest
                {
                    Name = form.Name,
                    ContactEmail = form.ContactEmail,
                    ContactPhone = form.ContactPhone,
                    BillingPlanId = planId,
                    PaymentTerms = form.PaymentTerms,
                    IsMultiTenant = form.IsMultiTenant,
                    ExternalPortalEnabled = form.ExternalPortalEnabled,
                    PortalBaseUrl = form.PortalBaseUrl,
                    PortalApiKey = form.PortalApiKey,
                    TradingPartnerIds = selectedPartnerIds.ToList()
                };
                if (await Api.CreateOrganizationAsync(req) != null)
                {
                    CloseModals();
                    await LoadOrganizations();
                }
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task ApproveOrganization(int id)
    {
        if (await Api.ApproveOrganizationAsync(id)) await LoadOrganizations();
    }

    private async Task RejectOrganization()
    {
        if (selectedOrganization == null) return;
        isSubmitting = true;
        try
        {
            if (await Api.RejectOrganizationAsync(selectedOrganization.Id, rejectReason))
            {
                CloseModals();
                await LoadOrganizations();
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task SuspendOrganization(int id)
    {
        if (await Api.SuspendOrganizationAsync(id)) await LoadOrganizations();
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "Active" => "bg-success",
        "Suspended" => "bg-danger",
        "Rejected" => "bg-danger",
        "Closed" => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private class OrgForm
    {
        public string Name { get; set; } = string.Empty;
        public string? ContactEmail { get; set; }
        public string? ContactPhone { get; set; }
        public string PaymentTerms { get; set; } = "CreditCard";
        public bool IsMultiTenant { get; set; }
        public bool ExternalPortalEnabled { get; set; }
        public string? PortalBaseUrl { get; set; }
        public string? PortalApiKey { get; set; }
    }
}
