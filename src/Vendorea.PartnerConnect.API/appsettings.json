{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=PartnerConnect;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Merchant360": {
    "BaseUrl": "http://localhost:5003",
    "ApiKey": "m360-callback-key-12345-not-for-production",
    "TokenEndpoint": "http://localhost:5003/oauth2/token",
    "ClientId": "partnerconnect-service",
    "ClientSecret": "PartnerConnect-Dev-Secret-2024!"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "AllowedHosts": "*",
  "FeatureFlags": {
    "EnableSprAdapter": true
  },
  "PartnerAdapters": {
    "SPR": {
      "BaseUrl": "https://api.sprpartner.example.com",
      "Username": "REPLACE_WITH_USERNAME",
      "Password": "REPLACE_WITH_PASSWORD",
      "PollingIntervalMinutes": 60
    }
  }
}
